{
  "enabled": true,
  "name": "Test After Spec Task",
  "description": "Запускає cargo test після завершення кожного spec task для раннього виявлення регресій",
  "version": "1",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "cargo test --workspace --no-fail-fast 2>&1 | tail -20",
    "timeout": 180
  },
  "shortName": "post-task-tests"
}
